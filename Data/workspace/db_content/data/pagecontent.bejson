    [
      "43075563-6a0d-42bc-8ff5-ec8d1c5ad7f8",
      "<p>This showcase features the <strong>Headless Gemini CLI Orchestrator</strong>. It demonstrates standardized BEJSON schemas for profiles, models, and key registries, orchestrated by a robust Python engine with Round Robin rotation and rate limiting.</p>",
      "",
      [
        {
          "filename": "prompter.py",
          "content": "#!/usr/bin/env python3\n\"\"\"\nOrchestrator: prompter.py\nDescription: CLI engine for standardized Gemini queries via BEJSON schemas.\n             Handles Round Robin keys, rate limits, and failure cooldowns.\n\"\"\"\nimport sys\nimport os\nimport json\nimport time\nimport requests\nimport argparse\nimport random\nfrom pathlib import Path\n\n# Setup Path for local libs\nBASE_DIR = Path(__file__).resolve().parent\nsys.path.append(str(BASE_DIR / \"lib\"))\n\ntry:\n    from lib_bejson_core import bejson_core_load_file\nexcept ImportError:\n    print(\"CRITICAL: Local libraries not found in lib/\")\n    sys.exit(1)\n\n# Persistent State for CLI Session (in-memory for this run)\nclass OrchestratorState:\n    current_key_idx = 0\n    last_request_time = 0\n    consecutive_errors = 0\n    cooldown_until = 0\n    is_initialized = False\n\nstate = OrchestratorState()\n\ndef initialize_state(pool_size):\n    if not state.is_initialized and pool_size > 0:\n        state.current_key_idx = random.randint(0, pool_size - 1)\n        state.is_initialized = True\n        print(f\"[*] Initialized session at random Key Slot {state.current_key_idx + 1}\")\n\ndef load_router():\n    with open(BASE_DIR / \"router.json\", \"r\") as f:\n        return json.load(f)\n\ndef get_active_model(model_path):\n    data = bejson_core_load_file(str(BASE_DIR / model_path))\n    fields = [f[\"name\"] for f in data[\"Fields\"]]\n    m_id_idx = fields.index(\"model_id\")\n    active_idx = fields.index(\"currently_active\")\n    \n    for row in data[\"Values\"]:\n        if row[active_idx] is True:\n            return row[m_id_idx]\n    return \"gemini-3-flash\" # Fallback\n\ndef get_keys(key_path):\n    data = bejson_core_load_file(str(BASE_DIR / key_path))\n    fields = [f[\"name\"] for f in data[\"Fields\"]]\n    k_idx = -1\n    for i, f in enumerate(data[\"Fields\"]):\n        if f[\"name\"] in (\"key\", \"api_key\"):\n            k_idx = i\n            break\n    \n    if k_idx == -1: return []\n    return [row[k_idx] for row in data[\"Values\"] if \"YOUR_GEMINI_KEY\" not in str(row[k_idx])]\n\ndef get_profile(profile_path):\n    data = bejson_core_load_file(str(BASE_DIR / profile_path))\n    fields = [f[\"name\"] for f in data[\"Fields\"]]\n    instr_idx = fields.index(\"SystemInstruction\")\n    return data[\"Values\"][0][instr_idx]\n\ndef send_query(prompt, router, model_override=None, output_file=None):\n    now = time.time()\n    \n    # 1. Check Cooldown\n    if state.cooldown_until > now:\n        rem = int((state.cooldown_until - now) / 60) + 1\n        print(f\"[-] System on COOLDOWN. Wait {rem} minute(s).\")\n        return False\n\n    # 2. Check Delay\n    delay = router[\"settings\"][\"request_delay_seconds\"]\n    diff = now - state.last_request_time\n    if diff < delay:\n        wait = int(delay - diff)\n        print(f\"[*] Rate limit: Sleeping for {wait}s...\")\n        time.sleep(wait)\n\n    # 3. Load Configs\n    model = model_override if model_override else get_active_model(router[\"routing\"][\"model\"])\n    keys = get_keys(router[\"routing\"][\"keys\"])\n    system_instruction = get_profile(router[\"routing\"][\"profile\"])\n    \n    if not keys:\n        print(\"[-] No valid keys found in registry.\")\n        return False\n\n    initialize_state(len(keys))\n    print(f\"[*] Preparing query (Model: {model})\")\n    state.last_request_time = time.time()\n    \n    attempts = 0\n    pool_errors = 0\n    \n    while attempts < len(keys):\n        key = keys[state.current_key_idx]\n        key_num = state.current_key_idx + 1\n        \n        # Advance for next time\n        state.current_key_idx = (state.current_key_idx + 1) % len(keys)\n        attempts += 1\n        \n        print(f\"[*] Sending via Key {key_num}/{len(keys)}...\")\n        url = f\"https://generativelanguage.googleapis.com/v1beta/models/{model}:generateContent?key={key}\"\n        \n        payload = {\n            \"contents\": [{\"parts\": [{\"text\": prompt}]}],\n            \"system_instruction\": {\"parts\": [{\"text\": system_instruction}]}\n        }\n        \n        try:\n            res = requests.post(url, json=payload, timeout=60)\n            res.raise_for_status()\n            data = res.json()\n            \n            if \"candidates\" in data and data[\"candidates\"]:\n                text = data[\"candidates\"][0][\"content\"][\"parts\"][0][\"text\"].strip()\n                if output_file:\n                    with open(output_file, \"w\") as f:\n                        f.write(text)\n                    print(f\"[+] Response saved to {output_file}\")\n                else:\n                    print(\"\\n=== GEMINI RESPONSE ===\\n\")\n                    print(text)\n                    print(\"\\n=======================\\n\")\n                state.consecutive_errors = 0\n                return True\n            else:\n                raise Exception(\"No candidates returned\")\n\n        except Exception as e:\n            print(f\"[-] Key {key_num} FAILED: {e}\")\n            pool_errors += 1\n            state.consecutive_errors += 1\n            \n            if pool_errors >= 2:\n                print(\"[-] Prompt HALTED: 2 keys failed in a row.\")\n                break\n                \n            if state.consecutive_errors >= router[\"settings\"][\"consecutive_error_limit\"]:\n                cd = router[\"settings\"][\"consecutive_error_limit\"]\n                state.cooldown_until = time.time() + (router[\"settings\"][\"cooldown_minutes\"] * 60)\n                print(f\"[-] Global TIMEOUT triggered.\")\n                break\n    return False\n\ndef main():\n    parser = argparse.ArgumentParser(description=\"Gemini Standardized Prompter\")\n    parser.add_argument(\"prompt\", nargs=\"?\", help=\"The prompt string\")\n    parser.add_argument(\"--model\", help=\"Override the active model ID\")\n    parser.add_argument(\"--output\", help=\"Save response to this file\")\n    \n    args = parser.parse_args()\n    router = load_router()\n    \n    if args.prompt:\n        send_query(args.prompt, router, args.model, args.output)\n    else:\n        print(\"Usage: python3 prompter.py \\\"prompt\\\" [--model model_id] [--output file.txt]\")\n\nif __name__ == \"__main__\":\n    main()\n"
        },
        {
          "filename": "router.json",
          "content": "{\n  \"routing\": {\n    \"profile\": \"configuration/bejson_schema_builder_profile.bejson\",\n    \"model\": \"configuration/gemini_model_template.104a.bejson\",\n    \"keys\": \"configuration/gemini_key_template.104a.bejson\"\n  },\n  \"settings\": {\n    \"request_delay_seconds\": 10,\n    \"consecutive_error_limit\": 3,\n    \"cooldown_minutes\": 5\n  }\n}\n"
        },
        {
          "filename": "gemini_profile_template.bejson",
          "content": "{\n  \"Format\": \"BEJSON\",\n  \"Format_Version\": \"104\",\n  \"Format_Creator\": \"Elton Boehnen\",\n  \"Records_Type\": [\n    \"AI_Profile\"\n  ],\n  \"Parent_Hierarchy\": \"/LLM_Configuration\",\n  \"Fields\": [\n    {\"name\": \"Record_Type_Parent\", \"type\": \"string\"},\n    {\"name\": \"Name\", \"type\": \"string\"},\n    {\"name\": \"Archetype\", \"type\": \"string\"},\n    {\"name\": \"Persona\", \"type\": \"string\"},\n    {\"name\": \"SystemInstruction\", \"type\": \"string\"},\n    {\"name\": \"ForbiddenTopics\", \"type\": \"array\"},\n    {\"name\": \"Avatar_Type\", \"type\": \"string\"},\n    {\"name\": \"Avatar_sourceUrl\", \"type\": \"string\"},\n    {\"name\": \"Avatar_Data\", \"type\": \"string\"},\n    {\"name\": \"MaxResponseTokens\", \"type\": \"integer\"},\n    {\"name\": \"Creativity\", \"type\": \"number\"},\n    {\"name\": \"Tone\", \"type\": \"array\"},\n    {\"name\": \"Formality\", \"type\": \"string\"},\n    {\"name\": \"Verbosity\", \"type\": \"string\"},\n    {\"name\": \"EmotionalExpression_Enabled\", \"type\": \"boolean\"},\n    {\"name\": \"EmotionalExpression_Intensity\", \"type\": \"number\"},\n    {\"name\": \"GoogleSearch_Enabled\", \"type\": \"boolean\"},\n    {\"name\": \"CodeInterpreter_Enabled\", \"type\": \"boolean\"},\n    {\"name\": \"EphemeralMemory\", \"type\": \"boolean\"},\n    {\"name\": \"CodeParsing_Mode\", \"type\": \"string\"},\n    {\"name\": \"CodeParsing_Languages\", \"type\": \"array\"},\n    {\"name\": \"CodeParsing_StructureValidation\", \"type\": \"boolean\"},\n    {\"name\": \"CodeParsing_VersionControl\", \"type\": \"boolean\"}\n  ],\n  \"Values\": [\n    [\n      \"AI_Profile\",\n      \"Gemini_Assistant\",\n      \"Tutor\",\n      \"Short description of the AI persona.\",\n      \"System instructions here...\",\n      [],\n      \"Emoji\",\n      \"\",\n      \"\ud83e\udd16\",\n      65536,\n      0.2,\n      [\"Professional\", \"Helpful\"],\n      \"Formal\",\n      \"Normal\",\n      false,\n      0.0,\n      true,\n      true,\n      true,\n      \"complete\",\n      [\"python\", \"javascript\"],\n      true,\n      true\n    ]\n  ]\n}\n"
        },
        {
          "filename": "gemini_key_template.104a.bejson",
          "content": "{\n  \"Format\": \"BEJSON\",\n  \"Format_Version\": \"104a\",\n  \"Format_Creator\": \"Elton Boehnen\",\n  \"Schema_Name\": \"ApiKeyRegistry\",\n  \"Records_Type\": [\n    \"ApiKey\"\n  ],\n  \"Fields\": [\n    {\n      \"name\": \"key_slot\",\n      \"type\": \"integer\"\n    },\n    {\n      \"name\": \"key\",\n      \"type\": \"string\"\n    }\n  ],\n  \"Values\": [\n    [\n      1,\n      \"AIzaSyDSigPdinl_SvWfo3-Z9-VdgSfXJ8ack8M\"\n    ],\n    [\n      2,\n      \"AIzaSyBwfXvW9ld0I5LYI4MjUlV00sBTH6oBw58\"\n    ],\n    [\n      3,\n      \"AIzaSyBTrZqRcAEnePAxQc4zKAKgnDvfQuyQcmc\"\n    ],\n    [\n      4,\n      \"AIzaSyB4ts9QPQVmjWaEdr_9UyJK92BnJ3a0crg\"\n    ],\n    [\n      5,\n      \"AIzaSyCrLMVq_L1MyoXTDa0-Z2Fmh2jWBtKOckM\"\n    ],\n    [\n      6,\n      \"AIzaSyD28Dl-_EwkmIzPD-eqiJm-dxKzafFplNI\"\n    ],\n    [\n      7,\n      \"AIzaSyDX8byingeNjrUJ0xzXPTm3hCJ6TJHkXIw\"\n    ],\n    [\n      8,\n      \"AIzaSyA65bO8Oc0lb8e_VogwSctfYzR0QLC1X7s\"\n    ],\n    [\n      9,\n      \"AIzaSyDX8byingeNjrUJ0xzXPTm3hCJ6TJHkXIw\"\n    ],\n    [\n      10,\n      \"AIzaSyA65bO8Oc0lb8e_VogwSctfYzR0QLC1X7s\"\n    ],\n    [\n      11,\n      \"AIzaSyAWIgqwD577T3CJ3etppWyzQze-7AQlVwo\"\n    ],\n    [\n      12,\n      \"AIzaSyCxfebB2La0gJqxHpyzneCk4Z8UYbEtQ2s\"\n    ],\n    [\n      13,\n      \"AIzaSyDiddjT8GK8-CONBllYX3qfn3FUBpIM7pM\"\n    ],\n    [\n      14,\n      \"AIzaSyASTr7NE1VJaTl6RVMbp_A53sQ9S8Yy2To\"\n    ]\n  ]\n}"
